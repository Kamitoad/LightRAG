# General
PROJECT_NAME=CourseWiki-RAG

# Haystack / NaiveRAG
# Development default: sentence_transformers. Final OpenAI comparison: openai.
EMBEDDING_PROVIDER=sentence_transformers
HAYSTACK_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
HAYSTACK_TOP_K=5
HAYSTACK_CHUNK_SIZE=1000
HAYSTACK_CHUNK_OVERLAP=150

# LLM Provider
# Development default: none. Final OpenAI comparison: openai.
LLM_PROVIDER=none
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Optional OpenAI-compatible provider
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Paths
PROCESSED_DATA_DIR=data/processed
EVALUATION_DIR=evaluation
